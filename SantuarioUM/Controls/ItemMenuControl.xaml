<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SantuarioUM.Controls.ItemMenuControl"
             x:Name="ControlReference">
    <Grid BackgroundColor="{Binding BackgroundColor}"
          BindingContext="{Binding ItemSource, Source={x:Reference ControlReference}}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="TapGestureRecognizer_OnTapped" />
        </Grid.GestureRecognizers>
        <Label Text="{Binding Title}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               FontSize="Large"
               FontAttributes="Bold"
               TextTransform="Uppercase"
               TextColor="{Binding TitleColor}" />
    </Grid>
</ContentView>