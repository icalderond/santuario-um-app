<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SantuarioUM.ViewModels"
             x:Class="SantuarioUM.Pages.ArticlePage"
             x:DataType="viewModels:ArticleViewModel"
             Title="{Binding CurrentMueble.Titulo}">
    <ContentPage.Content>
        <ScrollView Padding="15,10">
            <Grid RowDefinitions="auto, *">
                <StackLayout Spacing="15" Grid.Row="1">
                    <StackLayout>
                        <Label Text="Rito" FontAttributes="Bold"
                               TextTransform="Uppercase" />
                        <Image WidthRequest="100" HeightRequest="100"
                               BackgroundColor="LightGray" />
                        <Label Text="{Binding CurrentMueble.Dimensiones.Rito.Contenido}" />
                    </StackLayout>
                    <StackLayout>
                        <Label Text="Cumplimiento" FontAttributes="Bold"
                               TextTransform="Uppercase" />
                        <Image WidthRequest="100" HeightRequest="100"
                               BackgroundColor="LightGray" />
                        <Label Text="{Binding CurrentMueble.Dimensiones.Cumplimiento.Contenido}" />
                    </StackLayout>
                    <StackLayout>
                        <Label Text="Aplicación" FontAttributes="Bold"
                               TextTransform="Uppercase" />
                        <Image WidthRequest="100" HeightRequest="100"
                               BackgroundColor="LightGray" />
                        <Label Text="{Binding CurrentMueble.Dimensiones.Aplicacion.Contenido}" />
                    </StackLayout>
                </StackLayout>
            </Grid>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>