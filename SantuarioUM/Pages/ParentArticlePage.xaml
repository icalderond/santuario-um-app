<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SantuarioUM.ViewModels"
             xmlns:lang="clr-namespace:SantuarioUM.Resources.Languages"
             x:Class="SantuarioUM.Pages.ParentArticlePage"
             x:DataType="viewModels:ParentArticleViewModel"
             x:Name="ControlReference"
             BackgroundColor="{StaticResource Cottonseed}"
             Title="{Binding  CurrentArea.Titulo}">
    <ContentPage.Content>
        <ScrollView>
            <Grid Padding="15,0,15,10"
                  RowDefinitions="auto,auto,*">
                
                <!-- Image -->
                <Border StrokeThickness="0" Grid.Row="0"
                        Margin="0,10,0,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Image
                        WidthRequest="400"
                        HeightRequest="300"
                        BackgroundColor="Transparent"
                        Source="{Binding CurrentArea.Imagen}"
                        Aspect="AspectFill" />
                </Border>
                <Label Grid.Row="1" Text="{Binding CurrentArea.Descripcion}"
                       Margin="0,10,0,0" />
                
                <!-- Furniture list -->
                <Grid RowDefinitions="auto,*"
                      Grid.Row="2"
                      Margin="0,15,0,0">
                    <Label Text="{x:Static lang:TextResources.FurnituresText}" FontAttributes="Bold"
                           FontSize="Large" />
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding CurrentArea.Muebles}"
                                    ItemTemplate="{StaticResource FurnitureCardTemplate}"
                                    HeightRequest="200">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                        </CollectionView.ItemsLayout>
                    </CollectionView>
                </Grid>
            </Grid>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>