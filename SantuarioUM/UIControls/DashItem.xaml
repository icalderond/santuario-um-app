<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SantuarioUM.UIControls.DashItem"
             x:Name="ControlReference">
    <Border StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="25" />
        </Border.StrokeShape>
        <Grid>
            <Image Source="{Binding ImageSource, Source={x:Reference ControlReference}}"
                   Aspect="AspectFill">
            </Image>
            <Grid Background="{StaticResource BlackGradientBrush}" />
            <StackLayout Grid.RowSpan="2"
                         Padding="20,0,20,20"
                         VerticalOptions="End">
                <Label FontAttributes="Bold"
                       FontSize="Title"
                       Text="{Binding  TitleText, Source={x:Reference ControlReference}}"
                       TextColor="White" />
            </StackLayout>
        </Grid>
    </Border>
</ContentView>